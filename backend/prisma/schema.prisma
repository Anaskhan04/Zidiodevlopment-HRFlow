generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Organization {
  employees Employee[]
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
email String @unique
  phone     String?
  website   String?
  logoUrl   String?
  address   String?
country String
description String?
  timezone  String
  industry String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  
  id             String   @id @default(uuid())
  employeeCode   String   @unique

  firstName      String
  lastName       String

  email          String   @unique
  phone          String?

  designation    String
  department     String?

  joiningDate    DateTime

  salary         Float?

  status         String   @default("ACTIVE")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}