generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
email String @unique
  phone     String?
  website   String?
  logoUrl   String?
  address   String?
country String
description String?
  timezone  String
  industry String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}